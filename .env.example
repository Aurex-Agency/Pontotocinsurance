# Supabase Configuration
# Copy this file to `.env.local` and fill in the values from your Supabase
# dashboard (Settings > API). Never commit real keys or passwords.

# Public values (safe to expose in the browser)
NEXT_PUBLIC_SUPABASE_URL=https://ndgzmalrirbbeqbrgrjo.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Secret — keep this server-side only. Required for admin panel writes.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: direct PostgreSQL connection (only needed by some maintenance scripts)
# DATABASE_URL=postgresql://postgres:YOUR-DB-PASSWORD@db.ndgzmalrirbbeqbrgrjo.supabase.co:5432/postgres
